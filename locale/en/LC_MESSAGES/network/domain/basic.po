#: ../../source/network/domain/basic.rst:2
msgid "简介"
msgstr "Introduction"

#: ../../source/network/domain/basic.rst:3
msgid "DNS是一个简单的请求-响应协议，是将域名和IP地址相互映射的一个分布式数据库，能够使人更方便地访问互联网。DNS使用TCP和UDP协议的53端口。"
msgstr ""
"DNS is a simple request-response protocol and a distributed database that "
"maps domain names and IP addresses to each other, making the Internet easier "
"for people to use. DNS uses port 53 over both TCP and UDP."

#: ../../source/network/domain/basic.rst:6
msgid "请求响应"
msgstr "Request and Response"

#: ../../source/network/domain/basic.rst:9
msgid "DNS记录"
msgstr "DNS Records"

#: ../../source/network/domain/basic.rst:10
msgid "A"
msgstr "A"

#: ../../source/network/domain/basic.rst:11
msgid "返回域名对应的IPv4地址"
msgstr "Returns the IPv4 address corresponding to a domain name"

#: ../../source/network/domain/basic.rst:12
msgid "AAAA"
msgstr "AAAA"

#: ../../source/network/domain/basic.rst:13
msgid "NS"
msgstr "NS"

#: ../../source/network/domain/basic.rst:14
msgid "域名服务器"
msgstr "Name server"

#: ../../source/network/domain/basic.rst:15
msgid "返回该域名由哪台域名服务器解析"
msgstr "Returns which name server resolves the domain name"

#: ../../source/network/domain/basic.rst:16
msgid "PTR"
msgstr "PTR"

#: ../../source/network/domain/basic.rst:17
msgid "反向记录"
msgstr "Reverse record"

#: ../../source/network/domain/basic.rst:18
msgid "从IP地址到域名的记录"
msgstr "A record from an IP address to a domain name"

#: ../../source/network/domain/basic.rst:19
