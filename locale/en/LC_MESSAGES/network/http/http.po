msgid "404"
msgstr ""

#: ../../source/network/http/http.rst:284
msgid "未找到"
msgstr ""

#: ../../source/network/http/http.rst:284
msgid "服务器找不到请求的网页。"
msgstr ""

#: ../../source/network/http/http.rst:285
msgid "405"
msgstr ""

#: ../../source/network/http/http.rst:285
msgid "方法禁用"
msgstr ""

#: ../../source/network/http/http.rst:285
msgid "禁用请求中指定的方法。"
msgstr ""

