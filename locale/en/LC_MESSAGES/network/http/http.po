msgid "服务器已成功处理了请求。 通常，这表示服务器提供了请求的网页"
msgstr ""

#: ../../source/network/http/http.rst:250
msgid "201"
msgstr ""

#: ../../source/network/http/http.rst:250
msgid "已创建"
msgstr ""

#: ../../source/network/http/http.rst:250
msgid "请求成功并且服务器创建了新的资源"
msgstr ""

