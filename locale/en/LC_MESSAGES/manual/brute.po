#: ../../source/manual/brute.rst:2
msgid "爆破工具"
msgstr "Brute-Force Tools"

#: ../../source/manual/brute.rst:5
msgid "Hydra"
msgstr "Hydra"

#: ../../source/manual/brute.rst:6
msgid "``-R`` 继续从上一次进度破解"
msgstr "``-R`` Resume cracking from the previous progress"

#: ../../source/manual/brute.rst:7
msgid "``-S`` 使用SSL链接"
msgstr "``-S`` Use an SSL connection"

#: ../../source/manual/brute.rst:8
msgid "``-s<PORT>`` 指定端口"
msgstr "``-s<PORT>`` Specify the port"

#: ../../source/manual/brute.rst:9
msgid "``-l<LOGIN>`` 指定破解的用户"
msgstr "``-l<LOGIN>`` Specify the user to crack"

#: ../../source/manual/brute.rst:10
msgid "``-L<FILE>`` 指定用户名字典"
msgstr "``-L<FILE>`` Specify the username dictionary"

#: ../../source/manual/brute.rst:11
msgid "``-p<PASS>`` 指定密码破解"
msgstr "``-p<PASS>`` Specify the password to try"

#: ../../source/manual/brute.rst:12
msgid "``-P<FILE>`` 指定密码字典"
msgstr "``-P<FILE>`` Specify the password dictionary"

#: ../../source/manual/brute.rst:13
msgid "``-e<ns>`` 可选选项，n：空密码试探，s：使用指定用户和密码试探"
msgstr "``-e<ns>`` Optional checks: n tries an empty password; s tries the specified username as the password"

#: ../../source/manual/brute.rst:14
msgid "``-C<FILE>`` 使用冒号分割格式，例如\"user:pwd\"来代替-L/-P参数"
msgstr "``-C<FILE>`` Use colon-separated entries such as \"user:pwd\" instead of the -L/-P options"

#: ../../source/manual/brute.rst:15
msgid "``-M<FILE>`` 指定目标列表文件一行一条"
msgstr "``-M<FILE>`` Specify a target list file, one target per line"

#: ../../source/manual/brute.rst:16
msgid "``-o<FILE>`` 指定结果输出文件"
msgstr "``-o<FILE>`` Specify the result output file"

#: ../../source/manual/brute.rst:17
msgid "``-f`` 在使用-M参数以后，找到第一对登录名或者密码的时候中止破解"
msgstr "``-f`` When using -M, stop cracking after the first valid login/password pair is found"

#: ../../source/manual/brute.rst:18
msgid "``-t<TASKS>`` 同时运行的线程数，默认为16"
msgstr "``-t<TASKS>`` Number of concurrent tasks, default 16"

#: ../../source/manual/brute.rst:19
msgid "``-w<TIME>`` 设置最大超时的时间，单位秒，默认是30s"
msgstr "``-w<TIME>`` Set the maximum timeout in seconds, default 30s"

#: ../../source/manual/brute.rst:20
msgid "``-vV`` 显示详细过程"
msgstr "``-vV`` Show verbose progress"
