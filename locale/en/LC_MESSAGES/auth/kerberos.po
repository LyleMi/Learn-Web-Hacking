msgid "Principal(安全个体)"
msgstr ""

#: ../../source/auth/kerberos.rst:19
msgid "被认证的个体，有一个名字(name)和口令(password)"
msgstr ""

#: ../../source/auth/kerberos.rst:20
msgid "KDC (Key Distribution Center)"
msgstr ""

#: ../../source/auth/kerberos.rst:21
