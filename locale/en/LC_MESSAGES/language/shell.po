#: ../../source/language/shell.rst:2
msgid "Shell"
msgstr ""

#: ../../source/language/shell.rst:5
msgid "简介"
msgstr ""

#: ../../source/language/shell.rst:6
msgid "Shell 是一个特殊的程序，是用户使用 Linux 的桥梁。Shell 既是一种命令，又是一种程序设计语言。"
msgstr ""

#: ../../source/language/shell.rst:8
msgid "Linux 包含多种 Shell ，常见的有："
msgstr ""

#: ../../source/language/shell.rst:10
msgid "Bourne Shell（ATT的Bourne开发，名为sh）"
msgstr ""

#: ../../source/language/shell.rst:11
msgid "Bourne Again Shell（/bin/bash）"
msgstr ""

#: ../../source/language/shell.rst:12
msgid "C Shell（Bill Joy开发，名为csh）"
msgstr ""

#: ../../source/language/shell.rst:13
msgid "K Shell（ATT的David G.koun开发，名为ksh）"
msgstr ""

#: ../../source/language/shell.rst:14
msgid "Z Shell（Paul Falstad开发，名为zsh）"
msgstr ""

#: ../../source/language/shell.rst:17
msgid "元字符"
msgstr ""

#: ../../source/language/shell.rst:18
msgid "shell一般会有一系列特殊字符，用来实现的一定的效果，这种字符被称为元字符（Meta），不同的Shell支持的元字符可能会不相同。"
msgstr ""

#: ../../source/language/shell.rst:20
msgid "常见的元字符如下："
msgstr ""

#: ../../source/language/shell.rst:22
msgid "``IFS`` 由 <space> 或 <tab> 或 <enter> 三者之一组成"
msgstr ""

#: ../../source/language/shell.rst:23
msgid "``CR`` 由 <enter> 产生。"
msgstr ""

#: ../../source/language/shell.rst:24
msgid "``=`` 设定变量"
msgstr ""

#: ../../source/language/shell.rst:25
msgid "``$`` 作变量或运算替换"
msgstr ""

#: ../../source/language/shell.rst:26
msgid "``>`` 重定向 stdout"
msgstr ""

#: ../../source/language/shell.rst:27
msgid "``>>`` 追加到文件"
msgstr ""

#: ../../source/language/shell.rst:28
msgid "``<`` 重定向 stdin"
msgstr ""

#: ../../source/language/shell.rst:29
msgid "``|`` 命令管道"
msgstr ""

#: ../../source/language/shell.rst:30
msgid "``&`` 后台执行命令"
msgstr ""

#: ../../source/language/shell.rst:31
msgid "``;`` 在前一个命令结束后，执行下一个命令"
msgstr ""

#: ../../source/language/shell.rst:32
msgid "``&&`` 在前一个命令未报错执行后，执行下一个命令"
msgstr ""

#: ../../source/language/shell.rst:33
msgid "``||`` 在前一个命令执行报错后，执行下一个命令"
msgstr ""

#: ../../source/language/shell.rst:34
msgid "``'`` 在单引号内的命令会保留原来的值"
msgstr ""

#: ../../source/language/shell.rst:35
msgid "``\"`` 在双引号内的命令会允许变量替换"
msgstr ""

#: ../../source/language/shell.rst:36
msgid "````` 在反引号内的内容会当成命令执行并替换"
msgstr ""

#: ../../source/language/shell.rst:37
msgid "``()`` 在子Shell中执行命令"
msgstr ""

#: ../../source/language/shell.rst:38
#, python-brace-format
msgid "``{}`` 在当前Shell中执行命令"
msgstr ""

#: ../../source/language/shell.rst:39
msgid "``~`` 当前用户的主目录"
msgstr ""

#: ../../source/language/shell.rst:40
msgid "``!number`` 执行历史命令，如 ``!1``"
msgstr ""

#: ../../source/language/shell.rst:43
msgid "通配符"
msgstr ""

#: ../../source/language/shell.rst:44
msgid "除元字符外，通配符（wildcard）也是shell中的一种特殊字符。当shell在参数中遇到了通配符时，shell会将其当作路径或文件名去在磁盘上搜寻可能的匹配：若符合要求的匹配存在，则进行替换，否则就将该通配符作为一个普通字符直接传递。"
msgstr ""

#: ../../source/language/shell.rst:46
msgid "常见的通配符如下："
msgstr ""

#: ../../source/language/shell.rst:48
msgid "``*`` 匹配 0 或多个字符"
msgstr ""

#: ../../source/language/shell.rst:49
msgid "``?`` 匹配任意一个字符"
msgstr ""

#: ../../source/language/shell.rst:50
msgid "``[list]`` 匹配 list 中的任意一个字符"
msgstr ""

#: ../../source/language/shell.rst:51
msgid "``[!list]`` 匹配除 list 外的任意一个字符"
msgstr ""

#: ../../source/language/shell.rst:52
msgid "``[a-c]`` 匹配 a-c 中的任意一个字符"
msgstr ""

#: ../../source/language/shell.rst:53
#, python-brace-format
msgid "``{string1,string2,...}`` 分别匹配其中字符串"
msgstr ""
