#: ../../source/language/powershell.rst:71
msgid "进程"
msgstr "Processes"

#: ../../source/language/powershell.rst:72
msgid "启动进程 ``Start-Process calc``"
msgstr "Start a process with ``Start-Process calc``"

#: ../../source/language/powershell.rst:73
msgid "停止进程 ``Stop-Process -ID $pid``"
msgstr "Stop a process with ``Stop-Process -ID $pid``"

#: ../../source/language/powershell.rst:74
msgid "文件"
msgstr "Files"

#: ../../source/language/powershell.rst:75
#, python-brace-format
msgid "新建文件 ``New-Item #{file_path} -Force | Out-Null``"
msgstr "Create a file with ``New-Item #{file_path} -Force | Out-Null``"

#: ../../source/language/powershell.rst:76
#, python-brace-format
msgid "设置文件内容 ``Set-Content -Path #{file_path} -Value \"#{Content}\"``"
msgstr "Set file content with ``Set-Content -Path #{file_path} -Value \"#{Content}\"``"

#: ../../source/language/powershell.rst:77
#, python-brace-format
msgid "追加文件内容 ``Add-Content -Path #{file_path} -Value \"#{Content}\"``"
msgstr "Append file content with ``Add-Content -Path #{file_path} -Value \"#{Content}\"``"

#: ../../source/language/powershell.rst:78
msgid "复制文件 ``Copy-Item src dst``"
msgstr "Copy a file with ``Copy-Item src dst``"

#: ../../source/language/powershell.rst:79
#, python-brace-format
msgid "删除文件 ``Remove-Item #{outputfile} -Force -ErrorAction Ignore``"
msgstr "Delete a file with ``Remove-Item #{outputfile} -Force -ErrorAction Ignore``"

#: ../../source/language/powershell.rst:80
#, python-brace-format
msgid "子目录 ``Get-ChildItem #{file_path}``"
msgstr "List child directories with ``Get-ChildItem #{file_path}``"

#: ../../source/language/powershell.rst:81
msgid "服务"
msgstr "Services"

#: ../../source/language/powershell.rst:82
#, python-brace-format
msgid "获取服务 ``Get-Service -Name \"#{service_name}\"``"
msgstr "Get a service with ``Get-Service -Name \"#{service_name}\"``"

#: ../../source/language/powershell.rst:83
#, python-brace-format
msgid "启动服务 ``Start-Service -Name \"#{service_name}\"``"
msgstr "Start a service with ``Start-Service -Name \"#{service_name}\"``"

#: ../../source/language/powershell.rst:84
#, python-brace-format
msgid "停止服务 ``Stop-Service -Name \"#{service_name}\"``"
msgstr "Stop a service with ``Stop-Service -Name \"#{service_name}\"``"

#: ../../source/language/powershell.rst:85
#, python-brace-format
msgid "删除服务 ``Remove-Service -Name \"#{service_name}\"``"
msgstr "Delete a service with ``Remove-Service -Name \"#{service_name}\"``"

#: ../../source/language/powershell.rst:86
msgid "获取WMI支持 ``Get-WmiObject -list``"
msgstr "Get WMI support with ``Get-WmiObject -list``"

