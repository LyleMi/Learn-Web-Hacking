#: ../../source/language/php/unserialize.rst:39
msgid "object"
msgstr "object"

#: ../../source/language/php/unserialize.rst:40
#, python-brace-format
msgid "``O:<class_name_length>:\"<class_name>\":<number_of_properties>:{<properties>};``"
msgstr "``O:<class_name_length>:\"<class_name>\":<number_of_properties>:{<properties>};``"

#: ../../source/language/php/unserialize.rst:41
