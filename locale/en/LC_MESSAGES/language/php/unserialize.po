"``a:1:{s:4:\"key1\";s:6:\"value1\";}`` // ``array(\"key1\" => "
"\"value1\");``"
msgstr ""
"``a:1:{s:4:\"key1\";s:6:\"value1\";}`` // ``array(\"key1\" => "
