#: ../../source/language/php/sink.rst:21
msgid "Magic函数"
msgstr "Magic Methods"

#: ../../source/language/php/sink.rst:22
msgid "``__construct()`` 构建对象的时被调用"
msgstr "``__construct()`` is called when constructing an object."

#: ../../source/language/php/sink.rst:23
msgid "``__destruct()`` 销毁对象或脚本结束时被调用"
msgstr "``__destruct()`` is called when an object is destroyed or when the script ends."

#: ../../source/language/php/sink.rst:24
msgid "``__call()`` 调用不可访问或不存在的方法时被调用"
msgstr "``__call()`` is called when an inaccessible or nonexistent method is invoked."

#: ../../source/language/php/sink.rst:25
msgid "``__callStatic()`` 调用不可访问或不存在的静态方法时被调用"
msgstr "``__callStatic()`` is called when an inaccessible or nonexistent static method is invoked."

#: ../../source/language/php/sink.rst:26
msgid "``__get()`` 读取不可访问或不存在属性时被调用"
msgstr "``__get()`` is called when reading an inaccessible or nonexistent property."

#: ../../source/language/php/sink.rst:27
msgid "``__set()`` 给不可访问或不存在属性赋值时被调用"
msgstr "``__set()`` is called when assigning a value to an inaccessible or nonexistent property."

#: ../../source/language/php/sink.rst:28
msgid "``__isset()`` 对不可访问或不存在的属性调用 ``isset`` 或 ``empty()`` 时被调用"
msgstr "``__isset()`` is called when ``isset`` or ``empty()`` is used on an inaccessible or nonexistent property."

#: ../../source/language/php/sink.rst:29
msgid "``__unset()`` 对不可访问或不存在的属性进行 ``unset`` 时被调用"
msgstr "``__unset()`` is called when ``unset`` is used on an inaccessible or nonexistent property."

#: ../../source/language/php/sink.rst:30
msgid "``__sleep()`` 对象序列化时被调用"
msgstr "``__sleep()`` is called when an object is serialized."

#: ../../source/language/php/sink.rst:31
msgid "``__wakeup()`` 对象反序列化时被调用，其中序列化字符串中表示对象属性个数的值大于真实的属性个数时会跳过wakeup的执行"
msgstr "``__wakeup()`` is called when an object is unserialized. If the value representing the number of object properties in the serialized string is greater than the real number of properties, wakeup execution is skipped."

#: ../../source/language/php/sink.rst:32
msgid "``__toString()`` 当一个类被转换成字符串时被调用"
msgstr "``__toString()`` is called when a class is converted to a string."

#: ../../source/language/php/sink.rst:33
msgid "``__invoke()`` 对象被以函数方式调用时被调用"
msgstr "``__invoke()`` is called when an object is invoked as a function."

#: ../../source/language/php/sink.rst:34
msgid "``__set_state()`` 调用 ``var_export()`` 导出类时被调用"
msgstr "``__set_state()`` is called when a class is exported with ``var_export()``."

#: ../../source/language/php/sink.rst:35
msgid "``__clone()`` 进行对象clone时被调用"
msgstr "``__clone()`` is called when an object is cloned."

#: ../../source/language/php/sink.rst:36
msgid "``__debugInfo()`` 调用 ``var_dump()`` 打印对象时被调用"
msgstr "``__debugInfo()`` is called when an object is printed with ``var_dump()``."

