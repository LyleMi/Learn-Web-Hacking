msgstr "CAPTCHA is generated or verified on the client side"

#: ../../source/vuln/logic.rst:125
msgid "验证码可OCR或使用机器学习识别"
msgstr "CAPTCHA can be recognized with OCR or machine learning"

#: ../../source/vuln/logic.rst:126
msgid "验证码用于手机短信/邮箱轰炸"
msgstr "CAPTCHA is used for SMS or email bombing"

