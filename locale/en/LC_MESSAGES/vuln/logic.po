msgid "修改Cookie绕过"
msgstr "Bypass by modifying Cookie"

#: ../../source/vuln/logic.rst:123
msgid "修改返回包绕过"
msgstr "Bypass by modifying the response packet"

#: ../../source/vuln/logic.rst:124
