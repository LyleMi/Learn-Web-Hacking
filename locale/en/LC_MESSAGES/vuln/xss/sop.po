msgid "声明允许的访问方式"
msgstr ""

#: ../../source/vuln/xss/sop.rst:129
msgid "``Access-Control-Allow-Methods: <method>[, <method>]*``"
msgstr ""

#: ../../source/vuln/xss/sop.rst:130
msgid "Access-Control-Allow-Headers"
msgstr ""

#: ../../source/vuln/xss/sop.rst:131
