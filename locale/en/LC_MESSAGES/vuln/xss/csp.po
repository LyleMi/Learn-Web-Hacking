msgstr "e.g. ``img-src \\*.example.com``"

#: ../../source/vuln/xss/csp.rst:73
msgid "可以从任意example.com的子域处加载资源"
msgstr "Allows resources to be loaded from any subdomain of example.com"

#: ../../source/vuln/xss/csp.rst:74
msgid "``https://cdn.com``"
msgstr "``https://cdn.com``"

#: ../../source/vuln/xss/csp.rst:75
msgid "e.g. ``img-src https://cdn.com``"
msgstr "e.g. ``img-src https://cdn.com``"

#: ../../source/vuln/xss/csp.rst:76
msgid "只能从给定的域用https加载资源"
msgstr "Only allows resources to be loaded from the given domain over HTTPS"

#: ../../source/vuln/xss/csp.rst:77
msgid "``https:``"
msgstr "``https:``"

#: ../../source/vuln/xss/csp.rst:78
msgid "e.g. ``img-src https:``"
msgstr "e.g. ``img-src https:``"

#: ../../source/vuln/xss/csp.rst:79
msgid "只能从任意域用https加载资源"
msgstr "Only allows resources to be loaded over HTTPS from any domain"

#: ../../source/vuln/xss/csp.rst:80
msgid "``unsafe-inline``"
msgstr "``unsafe-inline``"

#: ../../source/vuln/xss/csp.rst:81
msgid "允许内部资源执行代码例如style attribute,onclick或者是sicript标签"
msgstr ""
"Allows inline resources to execute code, such as style attributes, onclick "
"handlers, or script tags"

#: ../../source/vuln/xss/csp.rst:82
msgid "e.g. ``script-src 'unsafe-inline'``"
msgstr "e.g. ``script-src 'unsafe-inline'``"

#: ../../source/vuln/xss/csp.rst:83
msgid "``unsafe-eval``"
msgstr "``unsafe-eval``"

#: ../../source/vuln/xss/csp.rst:84
msgid "允许一些不安全的代码执行方式，例如js的eval()"
msgstr "Allows some unsafe code execution methods, such as JS eval()"

#: ../../source/vuln/xss/csp.rst:85
msgid "e.g. ``script-src 'unsafe-eval'``"
msgstr "e.g. ``script-src 'unsafe-eval'``"

#: ../../source/vuln/xss/csp.rst:86
