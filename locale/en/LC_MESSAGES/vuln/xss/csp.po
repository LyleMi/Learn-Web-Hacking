#: ../../source/vuln/xss/csp.rst:56
msgid "``-``"
msgstr "``-``"

#: ../../source/vuln/xss/csp.rst:57
msgid "允许从任意url加载，除了 ``data:`` ``blob:`` ``filesystem:`` ``schemes``"
msgstr ""
"Allows loading from any URL except ``data:``, ``blob:``, ``filesystem:``, "
"and ``schemes``"

#: ../../source/vuln/xss/csp.rst:58
msgid "e.g. ``img-src -``"
msgstr "e.g. ``img-src -``"

#: ../../source/vuln/xss/csp.rst:59
msgid "``none``"
msgstr "``none``"

#: ../../source/vuln/xss/csp.rst:60
msgid "禁止从任何url加载资源"
msgstr "Forbids loading resources from any URL"

#: ../../source/vuln/xss/csp.rst:61
msgid "e.g. ``object-src 'none'``"
msgstr "e.g. ``object-src 'none'``"

#: ../../source/vuln/xss/csp.rst:62
msgid "``self``"
msgstr "``self``"

#: ../../source/vuln/xss/csp.rst:63
msgid "只可以加载同源资源"
msgstr "Only allows same-origin resources to be loaded"

#: ../../source/vuln/xss/csp.rst:64
msgid "e.g. ``img-src 'self'``"
msgstr "e.g. ``img-src 'self'``"

#: ../../source/vuln/xss/csp.rst:65
msgid "``data:``"
msgstr "``data:``"

#: ../../source/vuln/xss/csp.rst:66
msgid "可以通过data协议加载资源"
msgstr "Allows resources to be loaded through the data scheme"

#: ../../source/vuln/xss/csp.rst:67
msgid "e.g. ``img-src 'self' data:``"
msgstr "e.g. ``img-src 'self' data:``"

#: ../../source/vuln/xss/csp.rst:68
msgid "``domain.example.com``"
msgstr "``domain.example.com``"

#: ../../source/vuln/xss/csp.rst:69
msgid "e.g. ``img-src domain.example.com``"
msgstr "e.g. ``img-src domain.example.com``"

#: ../../source/vuln/xss/csp.rst:70
msgid "只可以从特定的域加载资源"
msgstr "Only allows resources to be loaded from a specific domain"

#: ../../source/vuln/xss/csp.rst:71
msgid "``\\*.example.com``"
msgstr "``\\*.example.com``"

#: ../../source/vuln/xss/csp.rst:72
