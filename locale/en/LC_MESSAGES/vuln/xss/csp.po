msgstr "``nonce-<base64-value>'``"

#: ../../source/vuln/xss/csp.rst:87
msgid "使用随机的nonce，允许加载标签上nonce属性匹配的标签"
msgstr ""
"Uses a random nonce and allows loading tags whose nonce attribute matches it"

#: ../../source/vuln/xss/csp.rst:88
msgid "e.g. ``script-src 'nonce-bm9uY2U='``"
msgstr "e.g. ``script-src 'nonce-bm9uY2U='``"

#: ../../source/vuln/xss/csp.rst:89
msgid "``<hash-algo>-<base64-value>'``"
msgstr "``<hash-algo>-<base64-value>'``"

#: ../../source/vuln/xss/csp.rst:90
msgid "允许hash值匹配的代码块被执行"
msgstr "Allows code blocks with matching hash values to execute"

#: ../../source/vuln/xss/csp.rst:91
msgid "e.g. ``script-src 'sha256-<base64-value>'``"
msgstr "e.g. ``script-src 'sha256-<base64-value>'``"

