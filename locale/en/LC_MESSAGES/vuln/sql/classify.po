msgstr ""

#: ../../source/vuln/sql/classify.rst:13
msgid "盲注"
msgstr ""

#: ../../source/vuln/sql/classify.rst:14
msgid "布尔盲注：只能从应用返回中推断语句执行后的布尔值"
msgstr ""

#: ../../source/vuln/sql/classify.rst:15
msgid "时间盲注：应用没有明确的回显，只能使用特定的时间函数来判断"
msgstr ""

#: ../../source/vuln/sql/classify.rst:16
msgid "报错注入：应用会显示全部或者部分的报错信息"
msgstr ""

#: ../../source/vuln/sql/classify.rst:17
msgid "堆叠注入：有的应用可以加入 ``;`` 后一次执行多条语句"
