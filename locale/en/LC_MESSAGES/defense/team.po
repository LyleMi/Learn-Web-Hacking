msgid "`初入甲方的企业安全建设规划 <https://mp.weixin.qq.com/s/BqOFP217kiN55IWb_oQP-w>`_"
msgstr "`Enterprise Security Construction Planning for New Internal Security Teams <https://mp.weixin.qq.com/s/BqOFP217kiN55IWb_oQP-w>`_"

#: ../../source/defense/team.rst:42
msgid "`企业安全项目架构实践分享 <https://mp.weixin.qq.com/s/RlBTH9-xrY7Nd1ZJK3KjDQ>`_"
msgstr "`Enterprise Security Project Architecture Practice Sharing <https://mp.weixin.qq.com/s/RlBTH9-xrY7Nd1ZJK3KjDQ>`_"

#: ../../source/defense/team.rst:43
msgid "`企业信息安全团队建设 <https://xz.aliyun.com/t/1965>`_"
msgstr "`Enterprise Information Security Team Building <https://xz.aliyun.com/t/1965>`_"
